describe('Auditoria de Acessibilidade - Mercado Livre', () => {
  it('Deve verificar erros de acessibilidade na página inicial', () => {
    // 1. Visita o site
    cy.visit('https://www.mercadolivre.com.br');
    
    // 2. Injeta o axe-core
    cy.injectAxe();
    
    // 3. Roda a auditoria e verifica se há violações
    cy.checkA11y(); 
  });
});
